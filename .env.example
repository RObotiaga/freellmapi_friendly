# Server encryption key for Provider Key storage.
# Required for normal startup. On an empty non-production first install,
# the server can generate this value into .env before any Provider Keys exist.
# Generate manually with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-key-here

# Admin Token for dashboard/admin API access.
# On a fresh local install, the dashboard can help you create this during
# the first 5 minutes after startup. For public or deployed instances, set
# this explicitly before starting the server.
# ADMIN_TOKEN=your-strong-admin-token-at-least-32-characters

# Local development only.
# Allows using a DB-stored Development Encryption Fallback when ENCRYPTION_KEY is not set.
# Never use this for real Provider Keys or production deployments.
# DEV_MODE=true

# Server port (default: 3001)
PORT=3001

# Network bind address.
# Defaults to 127.0.0.1. Public binding must be an explicit operator choice.
# HOST=0.0.0.0

# Comma-separated extra origins allowed to call the API from a browser.
# localhost:5173, 127.0.0.1:5173, [::1]:5173 are allowed by default for the
# Vite dev dashboard. Only set this if you serve the dashboard from a
# different host than the API (e.g. http://my-server.local).
# DASHBOARD_ORIGINS=http://my-server.local,http://192.168.1.50